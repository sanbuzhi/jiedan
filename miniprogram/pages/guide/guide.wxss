/* 引导页整体样式 */
page {
  height: 100%;
  background-color: #f5f7fa;
}

.guide-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 可滚动内容区域 */
.scrollable-content {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 顶部装饰区域 */
.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  overflow: hidden;
  z-index: 0;
}

.gradient-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, #07c160 0%, #10b981 50%, #059669 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.circle-decoration {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  top: 80rpx;
  right: 120rpx;
}

.circle-3 {
  width: 80rpx;
  height: 80rpx;
  bottom: 40rpx;
  left: 60rpx;
}

/* 标题区域 */
.title-section {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  margin-bottom: 20rpx;
}

.logo-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.2);
}

.logo {
  width: 80rpx;
  height: 80rpx;
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 滚动内容区域 */
.content-scroll {
  flex: 1;
  height: 0;
  padding: 0 30rpx;
  box-sizing: border-box;
}

/* 内容区块 */
.section {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-content {
  padding: 0 8rpx;
}

/* 功能介绍样式 */
.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* 流程说明样式 */
.flow-container {
  display: flex;
  flex-direction: column;
}

.flow-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.flow-number {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.flow-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.flow-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.flow-desc {
  font-size: 26rpx;
  color: #6b7280;
}

.flow-arrow {
  text-align: center;
  color: #07c160;
  font-size: 32rpx;
  padding: 8rpx 0;
  opacity: 0.6;
}

/* 用户须知样式 */
.notice-list {
  display: flex;
  flex-direction: column;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-dot {
  color: #07c160;
  font-size: 32rpx;
  margin-right: 16rpx;
  line-height: 1.4;
  flex-shrink: 0;
}

.notice-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.6;
  flex: 1;
}

/* 免责声明样式 */
.disclaimer-section {
  background: linear-gradient(135deg, #fefce8 0%, #fef9c3 100%);
  border: 2rpx solid #fde047;
}

.disclaimer-content {
  display: flex;
  flex-direction: column;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #854d0e;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.disclaimer-text:last-child {
  margin-bottom: 0;
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}

/* 底部按钮区域 */
.button-section {
  position: relative;
  z-index: 1;
  background: #ffffff;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: #f3f4f6;
  color: #4b5563;
  font-size: 30rpx;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  border: 2rpx solid #e5e7eb;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: #e5e7eb;
}

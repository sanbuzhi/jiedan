.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
  background: linear-gradient(180deg, #f2a55e 0%, #c8aa4f 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 区块样式 - 清新风格 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #00d4ff 0%, #0099ff 100%);
  border-radius: 3rpx;
}

.section-more {
  font-size: 26rpx;
  color: #0099ff;
  transition: all 0.3s ease;
}

.section-more:active {
  opacity: 0.7;
}

/* ==================== 我的项目区域 ==================== */
.projects-section {
  margin-top: 20rpx;
}

/* 无项目状态卡片 - 清新风格 */
.empty-project-card {
  background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);
  border: 2rpx dashed #00d4ff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 212, 255, 0.1);
}

.empty-project-card:active {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-color: #0099ff;
  transform: scale(0.98);
}

.empty-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 212, 255, 0.3);
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #666666;
}

/* 项目流程卡片容器 */
.project-flow-card-container {
  border-radius: 28rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

/* 添加项目按钮 */
.add-project-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #8BC34A 0%, #7CB342 100%);
  margin-top: 8rpx;
  transition: all 0.3s ease;
}

.add-project-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.add-project-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  margin-right: 12rpx;
}

.add-project-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 项目流程卡片 - 保持原有科技风 */
.project-flow-card {
  background: #112740;
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: 20rpx;
  padding: 30rpx;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
}

.project-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-btn {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
}

.delete-btn:active {
  opacity: 0.8;
}

.project-id {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
}

.project-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.project-status.pending {
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.2) 0%, rgba(250, 140, 22, 0.1) 100%);
  color: #fa8c16;
  border: 1rpx solid rgba(250, 140, 22, 0.3);
}

.project-status.processing {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(0, 153, 255, 0.1) 100%);
  color: #00d4ff;
  border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.project-status.developing {
  background: linear-gradient(135deg, rgba(0, 212, 170, 0.2) 0%, rgba(0, 212, 170, 0.1) 100%);
  color: #00d4aa;
  border: 1rpx solid rgba(0, 212, 170, 0.3);
}

.project-status.completed {
  background: linear-gradient(135deg, rgba(0, 212, 100, 0.2) 0%, rgba(0, 212, 100, 0.1) 100%);
  color: #00d464;
  border: 1rpx solid rgba(0, 212, 100, 0.3);
}

/* 流程时间线 - 水平滚动 - dashboard 风格 */
.flow-timeline-scroll {
  width: 100%;
  white-space: nowrap;
}

.flow-timeline-horizontal {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flow-node-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flow-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  min-width: 140rpx;
  position: relative;
  transition: all 0.3s ease;
}

/* completed 状态 - 绿色 */
.flow-node.completed {
  background: rgba(76, 175, 80, 0.15);
  border: 1rpx solid rgba(76, 175, 80, 0.4);
  color: #a5d6a7;
}

.flow-node.completed .flow-node-icon {
  color: #a5d6a7;
}

.flow-node.completed .flow-node-label {
  color: #a5d6a7;
}

/* active/current 状态 - 青色发光 */
.flow-node.active {
  background: rgba(0, 212, 255, 0.2);
  border: 1rpx solid #00d4ff;
  color: #00d4ff;
  animation: pulse 2s infinite;
}

.flow-node.active .flow-node-icon {
  color: #00d4ff;
}

.flow-node.active .flow-node-label {
  color: #00d4ff;
}

/* pending 状态 - 灰色 */
.flow-node.pending {
  background: rgba(107, 139, 163, 0.1);
  border: 1rpx solid rgba(107, 139, 163, 0.3);
  color: #6b8ba3;
}

.flow-node.pending .flow-node-icon {
  color: #6b8ba3;
}

.flow-node.pending .flow-node-label {
  color: #6b8ba3;
}

/* failed 状态 - 红色 */
.flow-node.failed {
  background: rgba(244, 67, 54, 0.15);
  border: 1rpx solid rgba(244, 67, 54, 0.4);
  color: #f44336;
}

.flow-node.failed .flow-node-icon {
  color: #f44336;
}

.flow-node.failed .flow-node-label {
  color: #f44336;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 5rpx rgba(0, 212, 255, 0.5);
  }
  50% {
    box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.8);
  }
}

.flow-node-icon {
  font-size: 28rpx;
  margin-bottom: 8rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* AI 工作中动态图标 */
.ai-working-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-robot {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.ai-head {
  font-size: 32rpx;
  animation: ai-bounce 1s ease-in-out infinite;
}

.ai-dots {
  display: flex;
  gap: 4rpx;
  margin-top: -8rpx;
}

.ai-dots .dot {
  width: 6rpx;
  height: 6rpx;
  background: #00d4ff;
  border-radius: 50%;
  animation: ai-dot-pulse 1.4s ease-in-out infinite;
}

.ai-dots .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.ai-dots .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes ai-bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
}

@keyframes ai-dot-pulse {
  0%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.flow-node-label {
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
  white-space: nowrap;
}

/* 点击提示 */
.flow-node-hint {
  font-size: 18rpx;
  color: #FF9800;
  margin-top: 4rpx;
  white-space: nowrap;
}

/* 箭头连接线 */
.flow-arrow {
  color: rgba(0, 212, 255, 0.3);
  font-size: 24rpx;
  margin: 0 16rpx;
}

/* ==================== 实时成交区域 ==================== */
.deals-section {
  margin-top: 20rpx;
}

/* 实时指示器 - 清新风格 */
.live-indicator {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(13, 205, 71, 0.1) 0%, rgba(13, 117, 35, 0.05) 100%);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 77, 79, 0.2);
}

.live-dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  border-radius: 50%;
  margin-right: 10rpx;
  animation: pulse 1.5s ease-in-out infinite;
  box-shadow: 0 0 10rpx rgba(255, 77, 79, 0.5);
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.9);
  }
}

.live-text {
  font-size: 22rpx;
  color: #ff4d4f;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 科技卡片 - 保持原有科技风 */
.tech-card {
  background: linear-gradient(135deg, rgba(10, 10, 15, 0.95) 0%, rgba(26, 26, 46, 0.95) 100%);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
}

.deals-container {
  height: 400rpx;
  overflow: hidden;
}

.deals-scroll {
  height: 100%;
}

.deal-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
  transition: all 0.3s ease;
}

.deal-item:last-child {
  border-bottom: none;
}

.deal-item:active {
  background: rgba(0, 212, 255, 0.05);
  border-radius: 12rpx;
}

.tech-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.3);
}

.deal-info {
  flex: 1;
}

.deal-user {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.deal-type {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.deal-amount {
  text-align: right;
}

.deal-price {
  display: block;
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
  margin-bottom: 6rpx;
  text-shadow: 0 0 10rpx rgba(255, 107, 107, 0.3);
}

.deal-time {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

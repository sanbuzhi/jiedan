.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #07c160 0%, #06ad56 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background-color: #ffffff;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 48rpx;
}

.feature-list {
  margin-bottom: 48rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.feature-icon {
  width: 40rpx;
  height: 40rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 20rpx;
}

.feature-text {
  font-size: 30rpx;
  color: #333333;
}

.login-btn {
  background-color: #07c160;
  color: #ffffff;
  border-radius: 12rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  margin-bottom: 32rpx;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  background-color: #06ad56;
}

.login-btn.disabled {
  background-color: #cccccc;
  color: #ffffff;
}

.privacy-tips {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.privacy-tips .link {
  color: #07c160;
}

.referral-section {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.referral-info {
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  text-align: center;
}

.referral-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.referral-code {
  display: block;
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 500;
}

<view class="container">
  <!-- 积分总额卡片 -->
  <view class="points-card">
    <text class="points-total-label">当前积分</text>
    <text class="points-total-value">{{totalPoints}}</text>
  </view>

  <!-- 积分记录列表 -->
  <view class="records-section">
    <view class="section-header">
      <text class="section-title">积分明细</text>
    </view>

    <view class="records-list">
      <block wx:for="{{pointRecords}}" wx:key="id">
        <view class="record-item">
          <view class="record-info">
            <text class="record-desc">{{item.description}}</text>
            <text class="record-time">{{formatDate(item.created_at)}}</text>
          </view>
          <text class="record-amount {{item.amount > 0 ? 'income' : 'expense'}}">
            {{item.amount > 0 ? '+' : ''}}{{item.amount}}
          </text>
        </view>
      </block>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{!isLoading && hasMore && pointRecords.length > 0}}">
      <text>上拉加载更多</text>
    </view>
    <view class="load-more" wx:if="{{isLoading}}">
      <text>加载中...</text>
    </view>
    <view class="load-more" wx:if="{{!hasMore && pointRecords.length > 0}}">
      <text>没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!isLoading && pointRecords.length === 0}}">
      <text>暂无积分记录</text>
    </view>
  </view>
</view>

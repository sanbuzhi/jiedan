.container {
  padding: 20rpx 30rpx 60rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 积分总额卡片 - 复用个人中心卡片样式 */
.points-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.points-total-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.points-total-value {
  font-size: 72rpx;
  font-weight: bold;
}

/* 记录区域 */
.records-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 记录列表 */
.records-list {
  min-height: 200rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-desc {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.4;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
}

.record-amount {
  font-size: 36rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 收入 - 绿色 */
.record-amount.income {
  color: #07c160;
}

/* 支出 - 红色 */
.record-amount.expense {
  color: #fa5151;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 26rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999999;
  font-size: 28rpx;
}

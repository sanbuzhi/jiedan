.container {
  padding: 20rpx 30rpx 60rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

/* 头像容器 */
.avatar-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
  cursor: pointer;
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

/* 头像遮罩层 */
.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.camera-icon {
  font-size: 40rpx;
}

/* 头像提示文字 */
.avatar-tip {
  display: inline-block;
  font-size: 22rpx;
  color: #F59E0B;
  background-color: rgba(245, 158, 11, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

.user-meta {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
}

.points-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.points-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.points-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 积分兑换按钮 */
.points-exchange-section {
  display: flex;
  justify-content: center;
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.exchange-btn {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}

.exchange-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.exchange-text {
  font-size: 26rpx;
  color: #ffffff;
}

/* 卡片通用样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.view-all {
  font-size: 26rpx;
  color: #07c160;
}

.share-btn {
  font-size: 26rpx;
  color: #07c160;
  background-color: rgba(7, 193, 96, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 推荐码卡片 */
.referral-code-section {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.code-display {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-right: 20rpx;
}

.code-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
}

.code-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  min-width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  color: #ffffff;
  background-color: #07c160;
}

.referral-tips {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 推荐树统计 */
.tree-summary {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.summary-value.level-1 {
  color: #07c160;
}

.summary-value.level-2 {
  color: #1890ff;
}

.summary-value.level-3 {
  color: #fa8c16;
}

.summary-label {
  font-size: 24rpx;
  color: #999999;
}

/* 推荐树列表 */
.tree-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.tree-item {
  margin-bottom: 16rpx;
}

.tree-user {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.tree-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.tree-avatar.small {
  width: 48rpx;
  height: 48rpx;
}

.tree-avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tree-avatar-placeholder.small {
  width: 48rpx;
  height: 48rpx;
}

.avatar-initial {
  font-size: 28rpx;
  font-weight: bold;
  color: #999999;
}

.avatar-initial.small {
  font-size: 20rpx;
}

.tree-info {
  flex: 1;
}

.tree-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.tree-date {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.tree-expand {
  padding: 8rpx;
}

.expand-icon {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.3s;
}

.expand-icon.expanded {
  transform: rotate(180deg);
}

.sub-tree {
  margin-left: 32rpx;
  margin-top: 12rpx;
  padding-left: 20rpx;
  border-left: 2rpx solid #e0e0e0;
}

.level-2-item .tree-user {
  background-color: #f0f7ff;
}

.level-3-item .tree-user {
  background-color: #fff7e6;
}

/* Canvas 画布样式 */
.canvas-container {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 20rpx;
}

.canvas-scroll-view {
  width: 100%;
  height: 100%;
  white-space: nowrap;
}

.referral-tree-canvas {
  display: inline-block;
  min-width: 100%;
  height: 100%;
}

/* 图例 */
.canvas-legend {
  position: absolute;
  bottom: 60rpx;
  left: 20rpx;
  display: flex;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.level-1 { background-color: #07c160; }
.legend-dot.level-2 { background-color: #2ca9e1; }
.legend-dot.level-3 { background-color: #fa5151; }

.legend-text {
  font-size: 20rpx;
  color: #666;
}

/* 操作提示 */
.canvas-hint {
  position: absolute;
  bottom: 16rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.hint-text {
  font-size: 20rpx;
  color: #999;
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

/* 积分记录 */
.points-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.points-item-record {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.points-item-record:last-child {
  border-bottom: none;
}

.points-info {
  flex: 1;
}

.points-desc {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.points-time {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.points-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.points-amount.positive {
  color: #07c160;
}

.points-amount.negative {
  color: #fa5151;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 退出登录 */
.logout-btn {
  margin-top: 40rpx;
  background-color: #fa5151;
  color: #ffffff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

.logout-btn::after {
  border: none;
}

/* 弹窗遮罩层 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗内容 */
.modal-content {
  background-color: #ffffff;
  border-radius: 24rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0;
  margin: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn.primary {
  color: #ffffff;
  background-color: #07c160;
}

.modal-btn.full-width {
  flex: none;
  width: 100%;
}

/* 分享规则弹窗 */
.share-rules-modal {
  width: 85%;
}

.rules-section {
  margin-bottom: 30rpx;
}

.rules-section:last-child {
  margin-bottom: 0;
}

.rules-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.rules-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.rules-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.rules-dot.level-1 {
  background-color: #07c160;
}

.rules-dot.level-2 {
  background-color: #1890ff;
}

.rules-dot.level-3 {
  background-color: #fa8c16;
}

.rules-text {
  font-size: 28rpx;
  color: #666666;
}

.rules-desc {
  display: flex;
  flex-direction: column;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
}

.rules-desc text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.rules-highlight {
  color: #07c160;
  font-weight: bold;
  margin-top: 8rpx;
}

/* 二维码预览弹窗 */
.qrcode-modal {
  width: 70%;
}

.qrcode-body {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
}

.qrcode-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 400rpx;
}

.qrcode-loading text {
  font-size: 28rpx;
  color: #999999;
}

/* 编辑个人资料弹窗 */
.edit-profile-modal {
  width: 85%;
}

.edit-header {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
}

.edit-header .modal-title {
  color: #ffffff;
}

.edit-header .close-icon {
  color: rgba(255, 255, 255, 0.8);
}

.edit-body {
  padding: 40rpx 30rpx;
}

/* 头像编辑区 */
.edit-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.edit-avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #E0E7FF;
  box-shadow: 0 4rpx 20rpx rgba(99, 102, 241, 0.2);
}

.edit-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.edit-avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: rgba(99, 102, 241, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-avatar-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 表单样式 */
.edit-form-item {
  margin-bottom: 30rpx;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  background-color: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1F2937;
  box-sizing: border-box;
}

.edit-input:focus {
  border-color: #6366F1;
  background-color: #ffffff;
}

.edit-hint {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
}

/* 底部按钮 */
.edit-footer {
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid #F3F4F6;
}

.edit-footer .modal-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.edit-footer .modal-btn.primary {
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.edit-footer .modal-btn.primary[disabled] {
  opacity: 0.6;
}

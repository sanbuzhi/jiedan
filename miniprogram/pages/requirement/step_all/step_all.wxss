/* ==================== 基础布局 ==================== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

/* ==================== 顶部固定导航 ==================== */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 进度指示器 */
.progress-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

/* 阶段序号 */
.step-number {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  color: #999999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
}

/* 阶段文字 */
.step-text {
  font-size: 24rpx;
  color: #999999;
  transition: all 0.3s ease;
}

/* 已完成状态 */
.progress-step.completed .step-number {
  background-color: #52c41a;
  color: #ffffff;
}

.progress-step.completed .step-text {
  color: #52c41a;
}

/* 进行中状态 */
.progress-step.active .step-number {
  background-color: #1890ff;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.4);
}

.progress-step.active .step-text {
  color: #1890ff;
  font-weight: 500;
}

/* 勾选标记 */
.step-check {
  font-size: 28rpx;
}

/* 连接线 */
.progress-line {
  width: 60rpx;
  height: 2rpx;
  background-color: #e0e0e0;
  margin: 0 16rpx;
  margin-bottom: 30rpx;
  transition: all 0.3s ease;
}

.progress-line.active {
  background-color: #52c41a;
}

/* ==================== 内容滚动区 ==================== */
.content-scroll {
  flex: 1;
  margin-top: 180rpx;
  margin-bottom: 140rpx;
  height: 0;
  overflow-y: auto;
}

/* 阶段区块 */
.stage-block {
  padding: 30rpx;
}

/* 阶段头部 */
.stage-header {
  margin-bottom: 40rpx;
}

.stage-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.stage-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 阶段内容 */
.stage-content {
  width: 100%;
}

/* ==================== 阶段1：需求智能解析 ==================== */

/* 输入卡片 */
.input-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.input-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.input-hint {
  font-size: 24rpx;
  color: #999999;
}

.requirement-textarea {
  width: 100%;
  min-height: 300rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
}

.requirement-textarea::placeholder {
  color: #bfbfbf;
}

/* 智能识别按钮 */
.analyze-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #e0e0e0;
  color: #999999;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  margin-bottom: 30rpx;
  transition: all 0.3s ease;
}

.analyze-btn::after {
  border: none;
}

.analyze-btn.active {
  background-color: #1890ff;
  color: #ffffff;
}

.analyze-btn.active:active {
  background-color: #096dd9;
}

.analyze-btn.loading {
  opacity: 0.8;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 角色区域 */
.roles-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 手风琴卡片 */
.role-accordion {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.role-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: all 0.3s ease;
}

.role-card.expanded {
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.role-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background-color: #ffffff;
  transition: all 0.3s ease;
}

.role-header:active {
  background-color: #f5f5f5;
}

.role-info {
  flex: 1;
  margin-right: 20rpx;
}

.role-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.role-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

.role-toggle {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toggle-icon {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.3s ease;
}

.role-card.expanded .toggle-icon {
  transform: rotate(180deg);
}

/* 功能点列表 */
.function-list {
  padding: 0 30rpx 30rpx;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.function-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.function-item:last-child {
  margin-bottom: 0;
}

.function-item:active {
  background-color: #e8e8e8;
}

.function-item.custom {
  background-color: #fff7e6;
  border: 1rpx solid #ffd591;
}

/* 功能点复选框 */
.function-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d9d9d9;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.function-checkbox.checked {
  background-color: #1890ff;
  border-color: #1890ff;
}

.checkbox-check {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 功能点信息 */
.function-info {
  flex: 1;
  margin-right: 16rpx;
}

.function-name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 6rpx;
}

.function-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 功能点标签 */
.function-tags {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.complexity-tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.complexity-tag.low {
  background-color: #f6ffed;
  color: #52c41a;
}

.complexity-tag.medium {
  background-color: #fff7e6;
  color: #fa8c16;
}

.complexity-tag.high {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.hours-tag {
  font-size: 22rpx;
  color: #999999;
}

/* 全选按钮 */
.select-all-bar {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.select-all-btn {
  display: inline-block;
  padding: 12rpx 30rpx;
  background-color: #f0f0f0;
  color: #666666;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.5;
}

.select-all-btn::after {
  border: none;
}

.select-all-btn:active {
  background-color: #e0e0e0;
}

/* 追加自定义功能按钮 */
.add-custom-bar {
  margin-top: 20rpx;
}

.add-custom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 20rpx;
  background-color: #e6f7ff;
  color: #1890ff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #91d5ff;
  transition: all 0.2s ease;
}

.add-custom-btn::after {
  border: none;
}

.add-custom-btn:active {
  background-color: #bae7ff;
}

.add-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  font-weight: bold;
}

/* 成本智能提示卡片 */
.cost-tips-card {
  display: flex;
  align-items: flex-start;
  background-color: #fffbe6;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #ffe58f;
  margin-bottom: 30rpx;
}

.cost-tips-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.cost-tips-content {
  flex: 1;
}

.cost-tips-text {
  display: block;
  font-size: 26rpx;
  color: #d48806;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.estimated-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 需求物料交付区 */
.materials-section {
  margin-top: 30rpx;
}

.material-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.material-header {
  margin-bottom: 20rpx;
}

.material-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

/* 图片预览 */
.image-preview-scroll {
  margin-bottom: 20rpx;
}

.image-preview-list {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.image-preview-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-image-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
}

/* 选择图片按钮 */
.choose-image-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 160rpx;
  background-color: #f8f9fa;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  color: #666666;
  font-size: 28rpx;
}

.choose-image-btn::after {
  border: none;
}

.choose-image-btn:active {
  background-color: #e8e8e8;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 已选文件显示 */
.selected-file {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f6ffed;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.file-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.file-name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.delete-file-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 选择文件按钮 */
.choose-file-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background-color: #f8f9fa;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  color: #666666;
  font-size: 28rpx;
}

.choose-file-btn::after {
  border: none;
}

.choose-file-btn:active {
  background-color: #e8e8e8;
}

/* 仓库链接输入 */
.repo-url-input {
  width: 100%;
  height: 88rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.repo-url-input::placeholder {
  color: #bfbfbf;
}

.input-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* ==================== 自定义功能弹窗 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999999;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 表单样式 */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-label.required::after {
  content: '*';
  color: #ff4d4f;
  margin-left: 8rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #bfbfbf;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #bfbfbf;
}

/* 复杂度选项 */
.complexity-options {
  display: flex;
  gap: 20rpx;
}

.complexity-option {
  flex: 1;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.complexity-option.selected {
  background-color: #e6f7ff;
  border-color: #1890ff;
}

.complexity-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.complexity-option.selected .complexity-name {
  color: #1890ff;
}

.complexity-hours {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 弹窗按钮 */
.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666666;
}

.modal-btn.cancel:active {
  background-color: #e8e8e8;
}

.modal-btn.confirm {
  background-color: #1890ff;
  color: #ffffff;
}

.modal-btn.confirm:active {
  background-color: #096dd9;
}

/* ==================== 阶段2：交互视觉定制 ==================== */

/* 选项卡片 */
.option-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.option-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.option-item.selected {
  background-color: #e6f7ff;
  border-color: #1890ff;
}

.option-item:active {
  background-color: #f5f5f5;
}

.option-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.option-icon.minimal {
  background-color: #f5f5f5;
}

.option-icon.business {
  background-color: #e6f7ff;
}

.option-icon.creative {
  background-color: #fff7e6;
}

.option-icon.cartoon {
  background-color: #f6ffed;
}

.option-info {
  flex: 1;
}

.option-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #e0e0e0;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.option-check.checked {
  background-color: #1890ff;
  border-color: #1890ff;
  position: relative;
}

.option-check.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #ffffff;
}

/* 配色方案 */
.color-list {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.color-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.color-item.selected {
  background-color: #e6f7ff;
  border-color: #1890ff;
}

.color-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.color-preview.blue {
  background: linear-gradient(135deg, #1890ff, #096dd9);
}

.color-preview.green {
  background: linear-gradient(135deg, #52c41a, #389e0d);
}

.color-preview.orange {
  background: linear-gradient(135deg, #fa8c16, #d46b08);
}

.color-preview.purple {
  background: linear-gradient(135deg, #722ed1, #531dab);
}

.color-name {
  font-size: 24rpx;
  color: #666666;
}

/* 布局偏好 */
.layout-list {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.layout-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s ease;
}

.layout-item.selected {
  background-color: #e6f7ff;
  border-color: #1890ff;
}

.layout-icon {

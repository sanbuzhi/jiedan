/* ==================== 基础布局 ==================== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* ==================== 顶部导航栏 ==================== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
  font-weight: 300;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
}

.header-placeholder {
  width: 60rpx;
}

/* ==================== 筛选标签栏 ==================== */
.filter-section {
  background-color: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 16rpx;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.filter-tag.active {
  background-color: #1890ff;
  color: #ffffff;
}

.filter-tag:active {
  opacity: 0.8;
}

/* ==================== 内容滚动区 ==================== */
.content-scroll {
  flex: 1;
  padding: 30rpx;
}

/* ==================== UI设计范式网格（3列） ==================== */
.style-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

/* 风格卡片 */
.style-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  position: relative;
}

.style-card.selected {
  border-color: #1890ff;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.2);
}

.style-card:active {
  transform: scale(0.95);
}

/* 卡片预览图 */
.card-preview {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.preview-elements {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.preview-shape {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: currentColor;
  opacity: 0.3;
}

.preview-lines {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.preview-line {
  width: 80rpx;
  height: 6rpx;
  background-color: currentColor;
  opacity: 0.5;
  border-radius: 3rpx;
}

.preview-line.short {
  width: 50rpx;
}

/* 卡片信息 */
.card-info {
  padding: 20rpx;
  text-align: center;
}

.card-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 选中标记 */
.card-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.4);
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}

/* ==================== 底部确认按钮 ==================== */
.footer {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #e0e0e0;
  color: #999999;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  transition: all 0.3s ease;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.active {
  background-color: #1890ff;
  color: #ffffff;
}

.confirm-btn.active:active {
  background-color: #096dd9;
}

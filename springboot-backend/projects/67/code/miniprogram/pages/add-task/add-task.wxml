<view class="container">
  <view class="form card">
    <view class="form-item">
      <view class="label">任务标题 <text class="required">*</text></view>
      <input class="input" placeholder="请输入任务标题" value="{{formData.title}}" bindinput="onTitleInput" />
    </view>
    <view class="form-item">
      <view class="label">任务内容</view>
      <textarea class="textarea" placeholder="请输入任务内容" value="{{formData.content}}" bindinput="onContentInput" />
    </view>
    <view class="form-item">
      <view class="label">优先级 <text class="required">*</text></view>
      <picker mode="selector" range="{{priorityList}}" range-key="label" value="{{priorityIndex}}" bindchange="onPriorityChange">
        <view class="picker">
          {{priorityList[priorityIndex].label}}
        </view>
      </picker>
    </view>
    <view class="form-item">
      <view class="label">截止时间</view>
      <picker mode="date" value="{{formData.deadline}}" bindchange="onDateChange">
        <picker mode="time" value="{{timeValue}}" bindchange="onTimeChange">
          <view class="picker">
            {{formData.deadline || '请选择截止时间'}}
          </view>
        </picker>
      </picker>
    </view>
  </view>

  <view class="btn-group">
    <button class="btn-cancel" bindtap="goBack">取消</button>
    <button class="btn-primary" bindtap="onSubmit">{{isEdit ? '保存修改' : '添加任务'}}</button>
  </view>
</view>
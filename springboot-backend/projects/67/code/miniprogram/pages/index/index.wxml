<view class="container">
  <!-- 用户信息和登录 -->
  <view class="header card" wx:if="{{!userInfo}}">
    <button class="login-btn" bindtap="handleLogin">微信一键登录</button>
  </view>
  <view class="header card" wx:else>
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname}}</view>
      <view class="task-count">当前共 {{taskList.length}} 个任务</view>
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="task-list">
    <view class="task-item card" wx:for="{{taskList}}" wx:key="id">
      <view class="task-left" bindtap="toggleStatus" data-id="{{item.id}}" data-status="{{item.status}}">
        <view class="checkbox {{item.status === 1 ? 'checked' : ''}}">
          <image wx:if="{{item.status === 1}}" src="assets/images/check.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="task-content">
        <view class="task-title {{item.status === 1 ? 'completed' : ''}}">{{item.title}}</view>
        <view class="task-meta">
          <text class="priority-{{item.priority === 1 ? 'low' : item.priority === 2 ? 'medium' : 'high'}}">
            {{item.priority === 1 ? '低' : item.priority === 2 ? '中' : '高'}}优先级
          </text>
          <text wx:if="{{item.deadline}}" class="deadline">截止: {{item.deadline}}</text>
        </view>
        <view wx:if="{{item.content}}" class="task-desc">{{item.content}}</view>
      </view>
      <view class="task-right">
        <view class="icon-btn edit" bindtap="editTask" data-id="{{item.id}}">编辑</view>
        <view class="icon-btn delete" bindtap="deleteTask" data-id="{{item.id}}">删除</view>
      </view>
    </view>
    <view wx:if="{{taskList.length === 0 && userInfo}}" class="empty">
      <image src="assets/images/empty.png" mode="aspectFit"></image>
      <view class="empty-text">暂无任务，快去添加吧~</view>
    </view>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="add-btn" bindtap="goToAdd">
    <image src="assets/images/add.png" mode="aspectFit"></image>
  </view>
</view>